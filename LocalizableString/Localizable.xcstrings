    "Camera is not available on this device. Would you like to use the photo library instead?" : {
      "localizations" : {
        "es-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cámara no está disponible en este dispositivo. ¿Prefieres usar la biblioteca de fotos?"
